config global
    option anon_swap '0'
    option anon_mount '0'
    option auto_swap '1'
    option auto_mount '1'
    option delay_root '5'
    option check_fs '0'

config mount 'automnt'
    option target '/mnt'
    option device 'tmpfs'
    option fstype 'tmpfs'
    option options 'ro,size=1M'
    option enabled '1'


#!/bin/sh /etc/rc.common
# nvrd-upload — C++ upload daemon (drains recorder DB queue to SFTP targets).
USE_PROCD=1
START=95
STOP=10

PROG=/usr/sbin/nvrd-upload
NAME=nvrd-upload

start_service() {
    procd_open_instance
    procd_set_param command "$PROG" \
        --db /mysql/data/db/nvr.db \
        run --pid-file /var/run/$NAME.pid --grace-ms 5000
    procd_set_param respawn 3600 5 5
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

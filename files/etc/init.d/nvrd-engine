#!/bin/sh /etc/rc.common
# nvrd-engine — Go supervisor; spawns nvr-recorder-rrtp + nvr-remuxer per camera.
# Status endpoint at 127.0.0.1:9090 (polled by nvrd-recorder).
#
# Per-device paths under /mnt/data/<DEVICE_ID>/ are resolved at start time
# from /etc/vuon_device_id (the factory image's immutable identity). The
# prior revision hardcoded a literal device_id ("evr26m4bk167") — every
# IB-built image inherited those paths, the supervisor's mount-gate
# CRITICALed because /mnt/data/<bk167>/raw didn't exist on a unit baked
# as anything else, and recorders refused to spawn. Reading the device id
# at start_service time makes the script identity-portable.
#
# -logs-dir none: per-process recorder/remuxer stderr is discarded (no disk
# logs) to keep disk-constrained units lean — matches the OTA-applied default
# (disk-reclaim, 2026-06-09). The supervisor's own stderr still flows to
# procd/syslog, and events.jsonl is unaffected. Set -logs-dir to a path to
# re-enable per-process disk logging for debugging.
USE_PROCD=1
START=93
STOP=10

PROG=/usr/sbin/nvrd-engine
NAME=nvrd-engine

start_service() {
    DEVICE_ID=$(cat /etc/vuon_device_id 2>/dev/null)
    if [ -z "$DEVICE_ID" ]; then
        echo "nvrd-engine: /etc/vuon_device_id missing or empty — refusing to start" >&2
        return 1
    fi
    DATA_ROOT="/mnt/data/$DEVICE_ID"
    mkdir -p "$DATA_ROOT/raw" "$DATA_ROOT/mp4" "$DATA_ROOT/state"

    procd_open_instance
    procd_set_param command "$PROG" \
        -db /mysql/data/db/nvr.db \
        -listen 127.0.0.1:9090 \
        -recorder-bin /usr/sbin/nvr-recorder-rrtp \
        -remuxer-bin  /usr/sbin/nvr-remuxer \
        -raw-dir   "$DATA_ROOT/raw" \
        -mp4-dir   "$DATA_ROOT/mp4" \
        -state-dir "$DATA_ROOT/state" \
        -logs-dir  none \
        -events-file "$DATA_ROOT/events.jsonl" \
        -emmc-monitor-path / \
        -disk-monitor-path /mnt/data
    procd_set_param respawn 300 5 0
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param pidfile /var/run/$NAME.pid
    procd_close_instance
}

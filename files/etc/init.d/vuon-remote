#!/bin/sh /etc/rc.common
# /etc/init.d/vuon-remote
# OpenWrt procd init script for the vuon_remote (frpc) tunnel.
#
# Auto-starts at boot (START=95, after networking) and respawns on
# crash up to 200 times within a 3600s window, with 5s between
# retries (~17 min worst case). After that procd gives up — bad
# device_id / token / template won't spam logread forever, and the
# failure is operator-visible.

START=95
STOP=10

USE_PROCD=1

PROG=/usr/bin/vuon_remote_start.sh

start_service() {
    procd_open_instance vuon-remote
    procd_set_param command "$PROG"
    procd_set_param respawn 3600 5 200
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_close_instance
}

stop_service() {
    return 0
}

reload_service() {
    stop
    start
}

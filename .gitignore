# --- OpenWRT ImageBuilder: build artifacts (regenerated by `make image`) ---
/build_dir/
/tmp/
/bin/

# Python caches (builder_agent.py)
__pycache__/
*.pyc

# Stale config / patch backups
*.bak
*.bak-*
/_patch-backups/

# --- Private signing keys (SECRETS — kept on disk, never committed) ---
/key-build
/key-build.ucert
/key-build.ucert.revoke
/keys/
